            { s: "천식", c: "감정 억압" },
            { s: "치질", c: "과거 집착" },
            { s: "코피", c: "인정 욕구" },
            { s: "탈모", c: "두려움, 통제 욕구" },
            { s: "편두통", c: "강제당함에 대한 혐오" },
            { s: "폐문제", c: "삶을 받아들이기 어려움" },
            { s: "피로", c: "저항, 지겨움" },
            { s: "피부문제", c: "공포, 위협 느낌" },
            { s: "항문 가려움", c: "죄의식" },
            { s: "허벅지 통증", c: "어린 시절 상처" },
            { s: "현기증", c: "혼란, 현실 회피" },
            { s: "호흡문제", c: "삶을 받아들이지 못함" },
            { s: "화상", c: "분노" },
            { s: "후두염", c: "말하지 못하는 분노" }
        ];

        // 초성 추출 함수 (한글만 해당)
        function getChoSung(str) {
            const cho = ["ㄱ", "ㄲ", "ㄴ", "ㄷ", "ㄸ", "ㄹ", "ㅁ", "ㅂ", "ㅃ", "ㅅ", "ㅆ", "ㅇ", "ㅈ", "ㅉ", "ㅊ", "ㅋ", "ㅌ", "ㅍ", "ㅎ"];
            const code = str.charCodeAt(0) - 44032;
            if (code > -1 && code < 11172) return cho[Math.floor(code / 588)];
            return str.charAt(0);
        }

        // 페이지 초기화
        const sidebarNav = document.getElementById('sidebarNav');
        const mainContent = document.getElementById('mainContent');
        const groups = {};

        // 데이터를 초성별로 그룹화
        data.forEach(item => {
            const cho = getChoSung(item.s);
            if (!groups[cho]) groups[cho] = [];
            groups[cho].push(item);
        });

        // HTML 생성
        Object.keys(groups).sort().forEach((cho, index) => {
            // 사이드바 링크
            const navLink = document.createElement('a');
            navLink.href = `#cho-${index}`;
            navLink.className = 'nav-link';
            navLink.innerText = cho;
            sidebarNav.appendChild(navLink);

            // 섹션 내용
            const section = document.createElement('section');
            section.id = `cho-${index}`;
            section.className = 'index-section';
            section.innerHTML = `<h2>${cho}</h2><ul class="link-grid"></ul>`;
            
            const ul = section.querySelector('ul');
            groups[cho].forEach(item => {
                const li = document.createElement('li');
                li.innerHTML = `<button onclick="openModal('${item.s}', '${item.c}')">${item.s}</button>`;
                ul.appendChild(li);
            });
            mainContent.appendChild(section);
        });

        // 모달 제어
        const modal = document.getElementById('modal');
        const flipCardElement = document.getElementById('flipCard');
        const modalSymptom = document.getElementById('modalSymptom');
        const modalCause = document.getElementById('modalCause');

        function openModal(symptom, cause) {
            modalSymptom.innerText = symptom;
            modalCause.innerText = cause;
            modal.style.display = 'flex';
            setTimeout(() => modal.classList.add('show'), 10);
            document.body.style.overflow = 'hidden';
        }

        function closeModal(e) {
            if (e.target.closest('.card') && !e.target.classList.contains('close-btn')) return;
            modal.classList.remove('show');
            flipCardElement.classList.remove('flipped');
            document.body.style.overflow = 'auto';
            setTimeout(() => { if (!modal.classList.contains('show')) modal.style.display = 'none'; }, 300);
        }

        function flipCard(e) {
            e.stopPropagation();
            flipCardElement.classList.toggle('flipped');
        }

        // ESC 지원 및 스크롤 스파이
        window.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(e); });
        
        const navLinks = document.querySelectorAll('.nav-link');
        const sections = document.querySelectorAll('.index-section');
        window.addEventListener('scroll', () => {
            let current = "";
            sections.forEach(s => { if (pageYOffset >= s.offsetTop - 100) current = s.id; });
            navLinks.forEach(l => {
                l.classList.remove("active");
                if (l.getAttribute("href").includes(current)) l.classList.add("active");
            });
        });
    </script>
</body>
</html>
